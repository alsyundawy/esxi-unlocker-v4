#!/bin/sh
# SPDX-License-Identifier: MIT
#
# unlock - Apply macOS unlock patches to VMware ESXi
#
# Description : Patches vmx, vmx-debug, vmx-stats (if non-empty), and
#               libvmkctl.so to enable macOS guest support on non-Apple
#               hardware running VMware ESXi 6.7, 7.x, and 8.x (U3 latest).
#
#               Based on DrDonk/unlocker 4.2.8 (14/05/26) as reference.
#               ESXi-specific deployment via VMTAR/pigz bootbank module.
#
# Usage       : unlock [-v|-h]
#   -v        : Enable verbose/debug output (set -x)
#   -h|--help : Show this help message
#
# Requirements: ESXi host in Maintenance Mode, no running VMs,
#               at least 400 MB free disk space on the datastore.
#
# Author      : drdonk / David Parsons
# Maintainer  : Harry DS Alsyundawy <alsyundawy@gmail.com>
# Copyright   : Copyright (c) 2007-2026 David Parsons
#               Copyright (c) 2024-2026 Harry DS Alsyundawy - Alsyundawy IT Solution
# License     : MIT
#
# Reference   : DrDonk/unlocker 4.2.8 (14/05/26) — Linux unlock binary
#               analysed: targets vmware-vmx + libvmwarebase.so (Workstation).
#               ESXi targets: /bin/vmx + /lib64/libvmkctl.so (different paths).
#               Backup and SHA-256 checksum features adopted from upstream Go.
#
# Changelog   :
#   2026-06-10 4.0.7a alsyundawy  Fix critical bug: chmod/tar wildcard glob in
#                                 staging included .bak and .sha256 audit files
#                                 generated by patchsmc/patchvmkctl into the
#                                 bootbank VMTAR (apple.v00) — wrong content.
#                                 Fix: purge staging audit files before chmod
#                                 and tar; use explicit file targets for chmod.
#                                 Add libvmkctl.so existence guard (not present
#                                 on all ESXi builds/versions).
#                                 Add python3 binary detection across ESXi 6.7
#                                 through 8 U3 (different venv paths per ver).
#   2026-06-10 4.0.7  alsyundawy  Reference DrDonk/unlocker 4.2.8. vmx-stats
#                                 existence check, backup, SHA-256, ESXi version
#                                 detection, -h/--help flag.
#   2026-06-10 4.0.6  alsyundawy  Fix critical bug: $1 arg on cp/rm/vmtar/pigz.
#                                 POSIX sh: read -p, [[ ]], ==. Subshell tar.
#                                 ./* glob. cd || exit guard.
#   2023-01-09 4.0.5  drdonk     Fixed permissions error correctly this time!
#   2023-01-03 4.0.4  drdonk     check/unlock free space and v3 detection.
#   2022-10-22 4.0.3  drdonk     Reinstate libvmkctl patch and boot time load.
#   2022-09-22 4.0.2  drdonk     Revert to binary read/writes in patchsmc.
#   2022-01-26 4.0.1  drdonk     Fix missing +x bit on checksmc, dumpsmc, relock.
#   2022-08-03 4.0.0  drdonk     Initial release.

# ---------------------------------------------------------------------------
# Safety: restrict to known-good system paths to avoid PATH hijacking attacks
# ---------------------------------------------------------------------------
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

# ---------------------------------------------------------------------------
# Detect python3 binary — location varies across ESXi 6.7 / 7.x / 8.x
# ESXi 6.7: /usr/lib/vmware/venv-65/bin/python3
# ESXi 7.0+: /usr/lib/vmware/venv-vsphere/bin/python3 or /usr/bin/python3
# ESXi 8.x: /usr/bin/python3
# ---------------------------------------------------------------------------
PYTHON3=''
for _py in /usr/bin/python3 \
           /usr/lib/vmware/venv-vsphere/bin/python3 \
           /usr/lib/vmware/venv-65/bin/python3; do
    if [ -x "$_py" ]; then
        PYTHON3="$_py"
        break
    fi
done
if [ -z "$PYTHON3" ]; then
    printf '%s\n' "${RED}>>> ERROR: python3 not found on this ESXi host <<<${RST}"
    exit 1
fi
printf 'Python3 path : %s\n' "$PYTHON3"

# ---------------------------------------------------------------------------
# ANSI color helpers (POSIX printf escape sequences)
# ---------------------------------------------------------------------------
RED='\033[41m\033[37m'
GRN='\033[32m'
YLW='\033[33m'
RST='\033[0m'

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
if [ $# -gt 1 ]; then
    printf '%s\n' "${RED}>>> ERROR: Too many arguments <<<${RST}"
    printf 'Usage: %s [-v|-h]\n' "$0"
    exit 1
fi

if [ $# -eq 1 ]; then
    case "$1" in
        -v)
            printf 'Verbose mode enabled\n'
            set -x
            ;;
        -h|--help)
            printf 'Usage: %s [-v|-h]\n' "$0"
            printf '  -v        Enable verbose/debug output\n'
            printf '  -h|--help Show this help message\n'
            exit 0
            ;;
        *)
            printf '%s\n' "${RED}>>> ERROR: Invalid option: $1 <<<${RST}"
            printf 'Usage: %s [-v|-h]\n' "$0"
            exit 1
            ;;
    esac
fi

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
printf 'VMware ESXi Unlocker 4.0.7\n'
printf '==========================\n'
printf 'Compatibility: ESXi 6.7 / 7.x / 8 U3 (latest)\n'
printf 'Reference    : DrDonk/unlocker 4.2.8 (14/05/26)\n'
printf '\nInstalling unlocker...\n'

# ---------------------------------------------------------------------------
# Pre-flight: ESXi version detection (informational)
# ---------------------------------------------------------------------------
ESXI_VERSION=$(vmware -v 2>/dev/null || printf 'Unknown')
printf 'ESXi version : %s\n' "$ESXI_VERSION"

# ---------------------------------------------------------------------------
# Pre-flight: disk space check (require 400 MB free)
# ---------------------------------------------------------------------------
REQUIRED=400
FREE=$(df -m . | tail -1 | awk '{print $4}')

if [ "$FREE" -lt "$REQUIRED" ]; then
    printf '%s\n' "${RED}>>> ERROR: Not enough free space: ${FREE} MB free, ${REQUIRED} MB required <<<${RST}"
    exit 1
fi
printf 'Disk space   : %s MB free (OK)\n' "$FREE"

# ---------------------------------------------------------------------------
# Pre-flight: detect leftover v3 installation
# ---------------------------------------------------------------------------
if [ -f "/bootbank/unlocker.tgz" ]; then
    printf '%s\n' "${RED}>>> ERROR: ESXi Unlocker v3 is installed and must be removed first <<<${RST}"
    printf 'Run:\n  BootModuleConfig.sh --verbose --remove=unlocker.tgz\nThen reboot.\n'
    exit 1
fi

# ---------------------------------------------------------------------------
# Resolve absolute path of this script and change to its directory
# ---------------------------------------------------------------------------
SCRIPT=$(readlink -f "$0")
SCRIPTPATH=$(dirname "$SCRIPT")
cd "$SCRIPTPATH" || {
    printf '%s\n' "${RED}>>> ERROR: Cannot change to script directory: $SCRIPTPATH <<<${RST}"
    exit 1
}

# ---------------------------------------------------------------------------
# Cleanup any artifacts from a previous (possibly failed) run
# ---------------------------------------------------------------------------
rm -rf ./tmp   2>/dev/null || true
rm -f  ./apple.* 2>/dev/null || true

# ---------------------------------------------------------------------------
# Create staging directory
# ---------------------------------------------------------------------------
mkdir -p ./tmp/bin
mkdir -p ./tmp/lib64
mkdir -p ./tmp/etc

# ---------------------------------------------------------------------------
# Copy vmx binaries to staging area
# Upstream 4.2.4+: check if vmx-stats exists before patching (ESXi 8.x guard)
# ---------------------------------------------------------------------------
printf '\nCopying ESXi binaries to staging area...\n'

cp /bin/vmx       ./tmp/bin/
cp /bin/vmx-debug ./tmp/bin/

# ESXi 8.x guard: vmx-stats may be a 0-byte stub or symlink — copy only if valid
if [ -f "/bin/vmx-stats" ] && [ -s "/bin/vmx-stats" ]; then
    cp /bin/vmx-stats ./tmp/bin/
    printf '%s\n' "${GRN}vmx-stats found and copied.${RST}"
else
    printf '%s\n' "${YLW}SKIP: /bin/vmx-stats is missing or empty (ESXi 8.x) — skipping.${RST}"
fi

# libvmkctl.so may not be present on all ESXi builds
if [ -f "/lib64/libvmkctl.so" ] && [ -s "/lib64/libvmkctl.so" ]; then
    cp /lib64/libvmkctl.so ./tmp/lib64/
    printf '%s\n' "${GRN}libvmkctl.so found and copied.${RST}"
else
    printf '%s\n' "${YLW}WARN: /lib64/libvmkctl.so missing or empty — skipping vmkctl patch.${RST}"
fi

# Ensure files are writable before patching (needed on NFS datastores)
# Use explicit targets — NOT wildcard glob — to avoid chmod on wrong files
chmod 4755 ./tmp/bin/vmx ./tmp/bin/vmx-debug 2>/dev/null || true
[ -f ./tmp/bin/vmx-stats ] && chmod 4755 ./tmp/bin/vmx-stats
[ -f ./tmp/lib64/libvmkctl.so ] && chmod 755 ./tmp/lib64/libvmkctl.so

# ---------------------------------------------------------------------------
# Record the ESXi version that this patch was built for
# ---------------------------------------------------------------------------
printf '%s\n' "$ESXI_VERSION" > ./tmp/etc/unlock.conf

# ---------------------------------------------------------------------------
# Apply SMC patches — patchsmc now creates .bak and .sha256 automatically
# ---------------------------------------------------------------------------
printf '\nPatching vmx binaries...\n'

"$PYTHON3" ./patchsmc patch ./tmp/bin/vmx
"$PYTHON3" ./patchsmc patch ./tmp/bin/vmx-debug

# Only patch vmx-stats if it was copied (non-empty file exists in staging)
if [ -f "./tmp/bin/vmx-stats" ] && [ -s "./tmp/bin/vmx-stats" ]; then
    "$PYTHON3" ./patchsmc patch ./tmp/bin/vmx-stats
else
    printf '%s\n' "${YLW}SKIP: vmx-stats not in staging — skipping patch.${RST}"
fi

# ---------------------------------------------------------------------------
# Apply vmkctl patch — only if libvmkctl.so was copied to staging
# ---------------------------------------------------------------------------
if [ -f "./tmp/lib64/libvmkctl.so" ]; then
    printf '\nPatching libvmkctl.so...\n'
    "$PYTHON3" ./patchvmkctl patch ./tmp/lib64/libvmkctl.so
fi

# ---------------------------------------------------------------------------
# CRITICAL: Remove .bak and .sha256 audit files from staging BEFORE chmod
# and BEFORE tar — they must NOT be packed into the bootbank VMTAR module.
# These files are created by patchsmc/patchvmkctl for auditing purposes only.
# ---------------------------------------------------------------------------
find ./tmp -name '*.bak'    -delete 2>/dev/null || true
find ./tmp -name '*.sha256' -delete 2>/dev/null || true

# ---------------------------------------------------------------------------
# Lock down permissions on patched files — use explicit targets, NOT globs
# vmx binaries: setuid + read/execute for all (4555 / -r-sr-xr-x)
# shared library: read/execute for all (555 / -r-xr-xr-x)
# ---------------------------------------------------------------------------
chmod 4555 ./tmp/bin/vmx ./tmp/bin/vmx-debug 2>/dev/null || true
[ -f ./tmp/bin/vmx-stats ]    && chmod 4555 ./tmp/bin/vmx-stats
[ -f ./tmp/lib64/libvmkctl.so ] && chmod 555  ./tmp/lib64/libvmkctl.so

# ---------------------------------------------------------------------------
# Build VMTAR archive (apple.v00) for ESXi bootbank
# ---------------------------------------------------------------------------
printf '\nBuilding apple.v00 VMTAR file...\n'

# 1. Create a plain TAR from staged files using a subshell to avoid cd back
#    Use ./* glob so filenames starting with '-' are safe
( cd ./tmp && tar cf ../apple.tar ./* )

# 2. Wrap the TAR into a VMTAR container
vmtar -c apple.tar -o apple.vtar 2>/dev/null

# 3. Compress VMTAR with pigz to produce a .v00 bootbank module
pigz -f -9 -n -T -k -S .v00 apple.vtar
mv -f apple.vtar.v00 apple.v00

# ---------------------------------------------------------------------------
# Cleanup intermediate files (keep .bak and .sha256 for auditing)
# ---------------------------------------------------------------------------
printf 'Cleaning up temporary files...\n'
rm -rf ./tmp
rm -f  apple.tar
rm -f  apple.vtar

# ---------------------------------------------------------------------------
# Register the module with ESXi bootbank
# ---------------------------------------------------------------------------
printf '\nAdding apple.v00 to bootbank...\n'
BootModuleConfig.sh --verbose --add=apple.v00

printf '\n%s\n' "${GRN}Unlocker 4.0.7 installed successfully.${RST}"
printf 'ESXi version patched: %s\n' "$ESXI_VERSION"

# ---------------------------------------------------------------------------
# Prompt for reboot (POSIX-safe: printf prompt then read without -p flag)
# ---------------------------------------------------------------------------
printf '\nReboot the ESXi server to activate the unlocker (y/N)? '
read -r response
case "$response" in
    [yY])
        printf 'Rebooting the ESXi server now...\n'
        reboot
        ;;
    *)
        printf '%s\n' "${YLW}NOTE: SMC patches will NOT be active until the ESXi server is rebooted.${RST}"
        ;;
esac

exit 0